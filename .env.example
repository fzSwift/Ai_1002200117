# --- $0 / no paid API (recommended for this project) ---
# Do not set OPENAI_API_KEY, or leave the placeholder below.
# Retrieval, embeddings (local), and the UI all work; "answers" show retrieved excerpts.
OPENAI_API_KEY=

# Optional: force offline even if you accidentally paste a key
# OFFLINE_MODE=1

# --- Local Ollama mode (no OpenAI billing) ---
USE_OLLAMA=1
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=

# --- Optional: Ollama Cloud mode ---
# OLLAMA_MODEL=gpt-oss:120b-cloud
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=your_ollama_api_key
